{
  "buildCommand": "npm run build --workspace=apps/frontend",
  "outputDirectory": "apps/frontend/build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "react",
  "regions": ["iad1"],
  "functions": {
    "apps/backend/**": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://skillbridge-api.vercel.app/api/:path*"
    }
  ]
}
